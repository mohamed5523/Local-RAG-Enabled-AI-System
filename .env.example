# ====================================
# LLM_AI Configuration
# ====================================
# Copy this file to .env and update values
# .env is NEVER committed to git

# OLLAMA CONFIGURATION
OLLAMA_HOST=http://localhost:11434
OLLAMA_CLI_MODEL=qwen2.5-coder:7b-instruct-q5_K_M
EMBEDDING_MODEL=nomic-embed-text

# MILVUS DATABASE
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530
MILVUS_COLLECTION=company_documents

# FASTAPI RAG SERVER
RAG_API_HOST=localhost
RAG_API_PORT=8001
UPLOAD_DIR=/app/uploads

# ⚠️ CHANGE THESE CREDENTIALS FOR PRODUCTION!
# MINIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ⚠️ CHANGE THIS SECRET KEY!
# Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBUI_SECRET_KEY=your-super-secret-key-change-this

# WEBUI CONFIGURATION
WEBUI_AUTH=true
WEBUI_MULTI_USER=true
WEBUI_NAME=R and D
DEFAULT_USER_ROLE=pending

# FEATURES
ENABLE_RAG_WEB_SEARCH=false
ENABLE_IMAGE_GENERATION=false

# PORTS
OPEN_WEBUI_PORT=8080
ATTU_PORT=8000

# RAG SETTINGS
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
DEFAULT_TOP_K=5
